# Valeraup — PRODUCTION environment variables (example).
#
# Copy to `.env.prod`, fill in REAL values, and keep it OUT of git (it holds
# secrets). Used by docker-compose.prod.yml via `--env-file .env.prod`:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod build
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Two distinct consumers read this file:
#   * Compose interpolation — POSTGRES_USER/PASSWORD/DB configure the `db`
#     service (the `${VAR}` references in docker-compose.prod.yml).
#   * Django/Celery — every var below is also passed into the backend/worker/
#     beat containers via `env_file`.
# DATABASE_URL MUST be consistent with the POSTGRES_* trio.

# --- PostgreSQL service (consumed by Compose to init the `db` container) ----
POSTGRES_USER=valeraup
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=valeraup

# --- Django core ------------------------------------------------------------
# DEBUG must be False in production (no detailed error pages, WhiteNoise serves
# static via the manifest, the dev-only /media route is disabled).
DEBUG=False
# Hostnames Django will answer to (your domain + the server IP). Comma-separated.
ALLOWED_HOSTS=valeraup.example.com,91.98.194.60
# Browser origins allowed to call the API. With the prod nginx proxy the SPA is
# same-origin, but list the public origin(s) explicitly for safety.
CORS_ALLOWED_ORIGINS=https://valeraup.example.com
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-generate-a-64-char-random-secret

# --- TLS / public host (Caddy reverse proxy) --------------------------------
# DOMAIN must resolve (A record) to this server with ports 80+443 reachable —
# Caddy auto-obtains + renews a Let's Encrypt cert for it (HTTPS, green lock).
# SERVER_IP keeps plain http working on the bare IP (a public CA cannot issue a
# certificate for a raw IP). Add DOMAIN to ALLOWED_HOSTS above too.
DOMAIN=valeraup.example.com
SERVER_IP=203.0.113.10

# --- Database (PostgreSQL) --------------------------------------------------
# Host is the compose service name `db`. Keep USER/PASSWORD/DB in sync with the
# POSTGRES_* values above.
DATABASE_URL=postgres://valeraup:CHANGE-ME-strong-db-password@db:5432/valeraup

# --- Celery / Redis ---------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Gemini OCR -------------------------------------------------------------
# Real key required for invoice recognition. If unset, recognize_invoice()
# short-circuits to [] (no OCR) — useful for a dry deploy, not for production.
GEMINI_API_KEY=CHANGE-ME-real-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# --- SalesDrive catalog export (YML) ----------------------------------------
# Source URL for the catalog sync (Admin → Синхронізувати / sync_catalog cmd).
SALESDRIVE_YML_URL=https://your-shop.salesdrive.ua/export/yml/

# --- Cloudflare R2 (S3-compatible object storage) ---------------------------
# RECOMMENDED in production: set all four so uploaded receipt photos and the
# generated .xlsx live in R2 (durable, served by R2 URLs — no media proxy
# needed). Leave them empty to fall back to the `media` named volume on the
# host (served via the nginx /media proxy in docker-compose.prod.yml).
R2_ACCESS_KEY_ID=CHANGE-ME-r2-access-key-id
R2_SECRET_ACCESS_KEY=CHANGE-ME-r2-secret-access-key
R2_BUCKET_NAME=valeraup-prod
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_REGION=auto

# --- JWT token lifetimes ----------------------------------------------------
# Short access token; long refresh (the PWA refreshes silently). Tune per
# security posture.
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=30
