# Valeraup backend environment variables (example).
#
# Copy to `.env` and fill in real values. The real file is git-ignored and must
# NEVER be committed. Placeholders below are safe defaults for local development
# with the bundled docker-compose stack.

# --- Django core ------------------------------------------------------------
SECRET_KEY=change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL) --------------------------------------------------
DATABASE_URL=postgres://valeraup:valeraup@db:5432/valeraup

# --- Celery / Redis ---------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Gemini OCR -------------------------------------------------------------
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# --- SalesDrive catalog export (YML) ----------------------------------------
SALESDRIVE_YML_URL=https://example.salesdrive.ua/export/yml/

# --- Cloudflare R2 (S3-compatible object storage) ---------------------------
# Leave R2_* empty to fall back to local FileSystemStorage in development.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_REGION=auto

# --- JWT token lifetimes ----------------------------------------------------
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=30
